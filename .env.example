# Copy this file to .env and replace every placeholder before starting Docker.
POSTGRES_USER=admin
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
POSTGRES_DB=iot_platform
DATABASE_URL=postgresql://admin:replace-with-a-strong-postgres-password@postgres:5432/iot_platform

MQTT_HOST=mosquitto
MQTT_PORT=1883

PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=replace-with-a-strong-pgadmin-password

SECRET_KEY=replace-with-a-cryptographically-random-jwt-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=true
